---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en' as const;

const posts = [
  {
    slug: 'v2-3-semantic-search-and-wysiwyg',
    title: 'v2.3 — Semantic search, WYSIWYG live edit, Windows portable',
    date: '2026-04-26',
    lead:
      'Search your notes by meaning, not just keywords — 100% on-device, no model file download. Plus a Typora-style live edit mode, a 10× Windows file-tree speedup, a portable .zip build, and a new internal MCP-driven self-test bridge.',
  },
  {
    slug: 'v2-2-mcp-autogit-and-14-ai-providers',
    title: 'v2.2 — MCP server, AutoGit version history, 14 AI providers',
    date: '2026-04-25',
    lead:
      'Every save is now a snapshot you can roll back from a sidebar panel. Every note is queryable from any MCP client (Claude Desktop, Cursor, etc.). AI rewrite spans 14 BYOK providers — keys live in the OS keychain, never on disk.',
  },
  {
    slug: 'v2-0-pkm-workspace',
    title: 'v2.0 — From Markdown editor to PKM workspace',
    date: '2026-04-25',
    lead:
      'Six features designed together as one cut: wikilinks + backlinks, spell-check, daily notes + tags, inline AI rewrite (14 providers), Pandoc export with @citekey citations, Bases-style properties view.',
  },
  {
    slug: 'v1-3-0-slideshow-cli-welcome',
    title: 'v1.3.0 — Slideshow, Welcome Tour & CLI',
    date: '2026-04-25',
    lead:
      'Render any markdown doc as fullscreen slides, a guided first-launch tour, a `solomd` CLI, Prettier formatting, and paragraph-level focus mode.',
  },
  {
    slug: 'v1-1-6-file-icons-and-native-print',
    title: 'v1.1.6 — File Icons & Native Print',
    date: '2026-04-23',
    lead:
      'A proper document icon for .md files, and Print (Cmd+P) now opens the real system print dialog on all three platforms.',
  },
];
---

<Layout
  title="SoloMD Blog"
  description="Release notes, development insights, and guides from the SoloMD team."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <section class="container blog-index">
      <h1>Blog</h1>
      <p class="lead">Release notes, workflow guides, and the occasional build-log.</p>

      <ul class="posts">
        {posts.map((p) => (
          <li class="post-item">
            <a href={`/blog/${p.slug}/`}>
              <time>{p.date}</time>
              <h2>{p.title}</h2>
              <p>{p.lead}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .blog-index { max-width: 820px; padding: 40px 20px 80px; }
  .blog-index h1 { font-size: 2rem; margin: 10px 0 14px; }
  .blog-index .lead { color: var(--text-muted, #555); margin-bottom: 32px; }
  .posts { list-style: none; padding: 0; margin: 0; }
  .post-item a { display: block; padding: 20px 0; border-bottom: 1px solid #eee; text-decoration: none; color: inherit; }
  .post-item time { font-size: 13px; color: var(--text-muted, #888); }
  .post-item h2 { margin: 4px 0 6px; font-size: 1.3rem; }
  .post-item p { margin: 0; color: var(--text-muted, #555); }
  .post-item a:hover h2 { color: #ff9f40; }
</style>
