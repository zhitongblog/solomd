---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import UseCases from '../../components/UseCases.astro';
import Principles from '../../components/Principles.astro';
import Features from '../../components/Features.astro';
import Compare from '../../components/Compare.astro';
import Download from '../../components/Download.astro';
import Faq from '../../components/Faq.astro';
import Contact from '../../components/Contact.astro';
import Sponsor from '../../components/Sponsor.astro';
import Footer from '../../components/Footer.astro';

const lang = 'de' as const;
---

<Layout
  title="SoloMD — Markdown-Editor, in dem Agents leben: Agent-Panel + geplante Recipes + Trace + MCP"
  description="Leichtgewichtiger Markdown-Editor (~15 MB, MIT). v4.0 fügt internes Agent-Panel, geplante Recipes, wiederholbaren Trace und Multi-Vault MCP-Federation hinzu. AutoGit-Branch-Sandbox bedeutet, autonome Schreibaktionen müssen accept/reject werden. 14 BYOK AI-Provider (Ollama enthalten)."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
