---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import UseCases from '../../components/UseCases.astro';
import Principles from '../../components/Principles.astro';
import Features from '../../components/Features.astro';
import Compare from '../../components/Compare.astro';
import Download from '../../components/Download.astro';
import Faq from '../../components/Faq.astro';
import Contact from '../../components/Contact.astro';
import Sponsor from '../../components/Sponsor.astro';
import Footer from '../../components/Footer.astro';

const lang = 'it' as const;
---

<Layout
  title="SoloMD — Editor Markdown dove vivono gli agent: Pannello Agent + Recipes pianificati + Trace + MCP"
  description="Editor Markdown leggero (~15 MB, MIT). v4.0 aggiunge pannello Agent incorporato, recipes pianificati, trace ripetibile e federazione MCP multi-vault. Sandbox di branch AutoGit significa che le scritture autonome devono essere accept/reject. 14 provider AI BYOK (Ollama incluso)."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
