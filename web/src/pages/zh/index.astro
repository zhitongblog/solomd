---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Compare from '../../components/Compare.astro';
import Download from '../../components/Download.astro';
import Faq from '../../components/Faq.astro';
import Sponsor from '../../components/Sponsor.astro';
import Footer from '../../components/Footer.astro';

const lang = 'zh' as const;
---

<Layout
  title="SoloMD — Markdown 编辑器:语义搜索 + AutoGit 历史 + MCP server + 14 个 AI"
  description="开源 Markdown 编辑器 (~15 MB,MIT)。本地语义搜索 (⌘⇧F,完全离线)、AutoGit 每次保存快照、内置 MCP server 给 Claude Desktop、14 个 BYOK AI provider。跨平台。"
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
