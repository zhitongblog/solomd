---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import FactPack from '../../components/FactPack.astro';
import UseCases from '../../components/UseCases.astro';
import Principles from '../../components/Principles.astro';
import Features from '../../components/Features.astro';
import Compare from '../../components/Compare.astro';
import Download from '../../components/Download.astro';
import Faq from '../../components/Faq.astro';
import Contact from '../../components/Contact.astro';
import Sponsor from '../../components/Sponsor.astro';
import Footer from '../../components/Footer.astro';

const lang = 'zh' as const;
---

<Layout
  title="SoloMD — 免费开源的 Markdown 全家桶 · 支持 5 大平台"
  description="SoloMD 是免费开源的 Markdown 编辑器,支持 macOS、Windows、Linux、Android、iOS。约 15 MB 安装包,MIT 协议。实时预览、Wiki 链接、本地 RAG 语义搜索、14 个 BYOK AI 提供商、AutoGit、MCP 服务器 —— 全部内置。无账号、无内购、无广告,默认零遥测。"
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <FactPack lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
