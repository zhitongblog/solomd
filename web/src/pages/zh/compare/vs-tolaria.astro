---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'zh' as const;

const tolariaVersion = '2026.6.6';

// 每行：[Tolaria 能力(html), Tolaria 标记, SoloMD 标记+说明(html)]
const featureGroups: { title: string; rows: [string, string, string][] }[] = [
  {
    title: '编辑器与写作',
    rows: [
      ['块编辑器（BlockNote、斜杠命令）', '✅', '🟡 有 WYSIWYG 实时编辑视图,但底层是 CodeMirror 源码'],
      ['Raw Markdown 模式（<code>⌘\\</code>）', '✅', '✅ 源码视图 + 分屏'],
      ['斜杠命令块菜单', '✅', '✅ 20 项命令面板（可关）'],
      ['双向链接 <code>[[note]]</code> + 自动补全', '✅', '✅'],
      ['行内 / 块级公式（KaTeX）', '✅', '✅ + 可编辑源码（v4.5.3）'],
      ['Mermaid 图', '✅', '✅ Mermaid 11'],
      ['Markdown 白板（tldraw）', '✅', '❌ <em>路线图中</em>'],
      ['表格 + 编辑内导航', '✅', '✅ GFM 表格'],
      ['目录 / 大纲面板', '✅', '✅ 大纲 + 跳行'],
      ['笔记宽度：正常 / 加宽', '✅', '✅ 预览适配宽度'],
      ['笔记内查找（<code>⌘F</code>）', '✅', '✅'],
      ['媒体 / PDF / 音视频预览', '✅', '✅'],
      ['自动保存（空闲去抖）', '✅', '✅ 每次保存即提交'],
      ['多标签 + 分屏', '❌ 每 vault 单标签', '✅ 标签页 + 任意分屏'],
      ['Vim 模式', '❌', '✅'],
      ['演讲 / 幻灯片模式', '❌', '✅ reveal.js（<code>⌘⌥P</code>）'],
      ['打字机 / 专注 / 禅模式', '❌', '✅ + 番茄钟'],
