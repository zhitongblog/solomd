---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const lang = 'zh' as const;

const posts = [
  {
    slug: 'v4-0-0-agent-native-author',
    title: 'v4.0 —— 让 Agent 住进来的编辑器',
    date: '2026-05-03',
    lead:
      'v4.0 是 agent-native author 大版本。五大支柱在内核里 —— 内置 Agent 面板（流式 chat-with-vault）、定时 Recipe（cron / on-save / on-commit, AutoGit 分支沙箱 + accept/reject）、可重放 Trace View、多 vault MCP Federation、Ollama 一等公民。同时:REST API、BYOK 成本计、11 个 Recipe 模板、首次启动向导。每一次 agent 运行都要先评审才能合入 main —— 五重不变量守同一条防线。',
  },
  {
    slug: 'v3-6-0-live-edit-blocks-and-polish',
    title: 'v3.6 —— 实时编辑下的图片 / 表格内联渲染，加 5 处打磨',
    date: '2026-04-29',
    lead:
      '实时编辑模式补齐了一直留着的缺口：整行图片和 GFM 表格现在能在编辑器里直接渲染，光标进入即源代码恢复。同时 5 处打磨 —— AI 按钮跳转、PNG 导出尺寸、可选水印、文件夹记忆、Mac 工具栏溢出修复。',
  },
  {
    slug: 'v3-5-5-font-fix-self-hosted-analytics',
    title: 'v3.5.5 —— Win 中文字体修复、自建匿名遥测、PR #48 polish',
    date: '2026-04-29',
    lead:
      '潜伏 6 周的 Win UI 中文字体回退终于被定位并修了。匿名遥测整体从 Aptabase 迁到自建 Cloudflare D1 端点，数据通路里再无第三方 SaaS。还有 @beihai23 的 PR #48：PDF 导出 30s 超时、outline 按钮搬到 tab、Mermaid 浮窗对比度。',
  },
  {
    slug: 'v2-3-semantic-search-and-wysiwyg',
    title: 'v2.3 —— 语义搜索、WYSIWYG 实时编辑、Windows 便携版',
    date: '2026-04-26',
    lead:
      '按意思而非关键词搜索笔记 —— 100% 本地，不下模型文件。Typora 风 WYSIWYG 实时所见即所得模式，Windows 文件树 10× 提速，新增便携版 .zip，以及一个内部用的 MCP 自测桥。',
  },
  {
    slug: 'v2-2-mcp-autogit-and-14-ai-providers',
    title: 'v2.2 —— MCP 服务、AutoGit 版本历史、14 家 AI 提供商',
    date: '2026-04-25',
    lead:
      '每次保存自动留快照，可在右侧面板一键回滚。任意 MCP 客户端（Claude Desktop / Cursor 等）都能查询你的笔记。AI 改写覆盖 14 家厂商 BYOK，key 存系统钥匙串、绝不落盘。',
  },
  {
    slug: 'v2-0-pkm-workspace',
    title: 'v2.0 —— 从 Markdown 编辑器到 PKM 工作台',
    date: '2026-04-25',
    lead:
      '6 个功能一次性发布：双向链接 + Backlinks、拼写检查、每日笔记 + 标签、AI 改写（14 个 provider）、Pandoc 导出 + @citekey 引用、Bases 属性表。',
  },
  {
    slug: 'v1-3-0-slideshow-cli-welcome',
    title: 'v1.3.0 —— 演讲模式、欢迎教程、CLI',
    date: '2026-04-25',
    lead:
      '把 Markdown 当 PPT 演讲，首次启动有引导教程，新增 solomd 命令行工具，Prettier 一键格式化，专注模式升级到段落级。',
  },
  {
    slug: 'v1-1-6-file-icons-and-native-print',
    title: 'v1.1.6 —— 文件图标与原生打印',
    date: '2026-04-23',
    lead:
      '.md 文件终于有了独立的文档图标，菜单 File → 打印 现在会弹系统原生打印对话框（三平台通用）。',
  },
];
---

<Layout
  title="SoloMD 博客"
  description="发布日志、开发笔记、使用技巧。"
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <section class="container blog-index">
      <h1>博客</h1>
      <p class="lead">发布日志、工作流指南、开发笔记。</p>

      <ul class="posts">
        {posts.map((p) => (
          <li class="post-item">
            <a href={`/zh/blog/${p.slug}/`}>
              <time>{p.date}</time>
              <h2>{p.title}</h2>
              <p>{p.lead}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  .blog-index { max-width: 820px; padding: 40px 20px 80px; }
  .blog-index h1 { font-size: 2rem; margin: 10px 0 14px; }
  .blog-index .lead { color: var(--text-muted, #555); margin-bottom: 32px; }
  .posts { list-style: none; padding: 0; margin: 0; }
  .post-item a { display: block; padding: 20px 0; border-bottom: 1px solid #eee; text-decoration: none; color: inherit; }
  .post-item time { font-size: 13px; color: var(--text-muted, #888); }
  .post-item h2 { margin: 4px 0 6px; font-size: 1.3rem; }
  .post-item p { margin: 0; color: var(--text-muted, #555); }
  .post-item a:hover h2 { color: #ff9f40; }
</style>
