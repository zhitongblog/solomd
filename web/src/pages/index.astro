---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Download from '../components/Download.astro';
import Sponsor from '../components/Sponsor.astro';
import Footer from '../components/Footer.astro';

const lang = 'en' as const;
---

<Layout
  title="SoloMD — Lightweight Markdown editor"
  description="A lightweight, cross-platform Markdown + plain text editor for macOS, Windows, and Linux. One file. One window. Just write."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Features lang={lang} />
    <Download lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
