---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import UseCases from '../components/UseCases.astro';
import Principles from '../components/Principles.astro';
import Features from '../components/Features.astro';
import Compare from '../components/Compare.astro';
import Download from '../components/Download.astro';
import Faq from '../components/Faq.astro';
import Sponsor from '../components/Sponsor.astro';
import Footer from '../components/Footer.astro';

const lang = 'en' as const;
---

<Layout
  title="SoloMD — Markdown editor with semantic search, AutoGit history, MCP server, 14 AI providers"
  description="Open-source Markdown editor (~15 MB, MIT). Local semantic search (⌘⇧F, no cloud). AutoGit per-save snapshots. MCP server for Claude Desktop. 14 BYOK AI providers. Cross-platform."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
