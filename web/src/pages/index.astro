---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import FactPack from '../components/FactPack.astro';
import UseCases from '../components/UseCases.astro';
import Principles from '../components/Principles.astro';
import Features from '../components/Features.astro';
import Compare from '../components/Compare.astro';
import Download from '../components/Download.astro';
import Faq from '../components/Faq.astro';
import Contact from '../components/Contact.astro';
import Sponsor from '../components/Sponsor.astro';
import Footer from '../components/Footer.astro';

const lang = 'en' as const;
---

<Layout
  title="SoloMD — Free & open-source Markdown editor · a Typora alternative for Mac, Windows, Linux, iOS, Android"
  description="Everything you'd pay a Markdown editor for — free. SoloMD is an open-source Typora alternative: live WYSIWYG preview, tabs, themes, PDF / Word export, plus AI rewrite, folder sync, local RAG search, and native iOS & Android apps. ~15 MB, MIT-licensed. No account, no subscription, no ads, zero telemetry by default."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <FactPack lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
    <Sponsor lang={lang} />
    <section style="max-width:860px;margin:8px auto 0;padding:0 20px 56px;">
      <a href="https://doaipm.com/en/presale?utm_source=solomd" target="_blank" rel="noopener"
         style="display:flex;gap:16px;align-items:center;flex-wrap:wrap;padding:22px 24px;border-radius:16px;text-decoration:none;color:inherit;border:1px solid rgba(120,120,180,.28);background:linear-gradient(135deg,rgba(99,102,241,.12),rgba(139,92,246,.06));">
        <span style="font-size:26px;line-height:1;">🚀</span>
        <span style="flex:1;min-width:240px;">
          <span style="display:block;font-size:17px;font-weight:800;">SoloMD was built by one person — with AI.</span>
          <span style="display:block;font-size:14.5px;opacity:.72;margin-top:5px;line-height:1.55;">Want to ship a real product solo with Claude Code? I wrote down the exact pipeline — idea → spec → build → QA → ship. Early-bird presale.</span>
        </span>
        <span style="font-size:14px;font-weight:800;color:#6366f1;white-space:nowrap;">Learn the playbook →</span>
      </a>
    </section>
  </main>
  <Footer lang={lang} />
</Layout>
