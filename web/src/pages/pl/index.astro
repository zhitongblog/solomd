---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import UseCases from '../../components/UseCases.astro';
import Principles from '../../components/Principles.astro';
import Features from '../../components/Features.astro';
import Compare from '../../components/Compare.astro';
import Download from '../../components/Download.astro';
import Faq from '../../components/Faq.astro';
import Contact from '../../components/Contact.astro';
import Sponsor from '../../components/Sponsor.astro';
import Footer from '../../components/Footer.astro';

const lang = 'pl' as const;
---

<Layout
  title="SoloMD — edytor Markdown, w którym mieszkają agenty: panel Agent + zaplanowane Recipes + Trace + MCP"
  description="Lekki edytor Markdown (~15 MB, MIT). v4.0 dodaje wbudowany panel Agent, zaplanowane recipes, odtwarzalny trace i federację MCP multi-vault. Sandbox branchy AutoGit oznacza, że autonomiczne zapisy muszą przejść accept/reject. 14 dostawców AI w trybie BYOK (w tym Ollama)."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
