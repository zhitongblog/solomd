---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import UseCases from '../../components/UseCases.astro';
import Principles from '../../components/Principles.astro';
import Features from '../../components/Features.astro';
import Compare from '../../components/Compare.astro';
import Download from '../../components/Download.astro';
import Faq from '../../components/Faq.astro';
import Contact from '../../components/Contact.astro';
import Sponsor from '../../components/Sponsor.astro';
import Footer from '../../components/Footer.astro';

const lang = 'pt' as const;
---

<Layout
  title="SoloMD — Editor Markdown onde os agentes vivem: Painel Agent + Recipes agendados + Trace + MCP"
  description="Editor Markdown leve (~15 MB, MIT). v4.0 adiciona painel Agent embutido, recipes agendados, trace reproduzível e federação MCP multi-vault. Sandbox de branch AutoGit significa que escritas autônomas devem ser accept/reject. 14 providers IA BYOK (Ollama incluído)."
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <UseCases lang={lang} />
    <Principles lang={lang} />
    <Features lang={lang} />
    <Compare lang={lang} />
    <Download lang={lang} />
    <Faq lang={lang} />
    <Contact lang={lang} />
    <Sponsor lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
