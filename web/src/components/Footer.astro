---
import { getT, type Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = getT(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="brand-mark"><span class="h">#</span><span class="md">MD</span></span>
      <span class="footer__name">SoloMD</span>
    </div>
    <div class="footer__links">
      <a href={lang === 'zh' ? '/zh/compare/' : '/compare/'}>{lang === 'zh' ? '对比' : 'Compare'}</a>
      <a href={lang === 'zh' ? '/zh/docs/' : '/docs/'}>{lang === 'zh' ? '文档' : 'Docs'}</a>
      <a href={lang === 'zh' ? '/zh/blog/' : '/blog/'}>{lang === 'zh' ? '博客' : 'Blog'}</a>
      <a href={lang === 'zh' ? '/zh/community/' : '/community/'}>{tr.footer.community}</a>
      <a href={lang === 'zh' ? '/zh/thanks/' : '/thanks/'}>{lang === 'zh' ? '鸣谢' : 'Thanks'}</a>
      <a href={lang === 'zh' ? '/zh/security/' : '/security/'}>{lang === 'zh' ? '安全' : 'Security'}</a>
      <a href="https://github.com/zhitongblog/solomd" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/zhitongblog/solomd/releases" target="_blank" rel="noopener">Releases</a>
      <a href="https://github.com/zhitongblog/solomd/blob/main/LICENSE" target="_blank" rel="noopener">License</a>
    </div>
    <div class="footer__legal">
      © {year} xiangdong li · {tr.footer.legal}
      <br />
      {tr.footer.stack}
    </div>
  </div>
</footer>

<style>
  /* Dark footer acts as the page's visual anchor — same role Anthropic's
     near-black footer plays. Inverts colors locally so the brand mark's
     orange # still pops against ink, but everything else fades to a
     calm bone-white. */
  .footer {
    padding: 64px 0 56px;
    background: #14140f;
    color: #c5c2b9;
    border-top: none;
  }
  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }
  .footer__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    color: #f3efe7;
  }
  .footer__brand .brand-mark .md { color: #f3efe7; }
  .footer__name { font-weight: 600; }
  .footer__links {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .footer__links a {
    color: #c5c2b9;
    font-size: 13px;
    transition: color 0.18s;
  }
  .footer__links a:hover { color: var(--accent); text-decoration: none; }
  .footer__legal {
    font-size: 11px;
    color: #7a7770;
    line-height: 1.8;
    max-width: 640px;
  }
</style>
