---
import { getT, type Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = getT(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="brand-mark"><span class="h">#</span><span class="md">MD</span></span>
      <span class="footer__name">SoloMD</span>
    </div>
    <div class="footer__links">
      <a href={lang === 'zh' ? '/zh/compare/' : '/compare/'}>{lang === 'zh' ? '对比' : 'Compare'}</a>
      <a href={lang === 'zh' ? '/zh/docs/' : '/docs/'}>{lang === 'zh' ? '文档' : 'Docs'}</a>
      <a href={lang === 'zh' ? '/zh/blog/' : '/blog/'}>{lang === 'zh' ? '博客' : 'Blog'}</a>
      <a href={lang === 'zh' ? '/zh/thanks/' : '/thanks/'}>{lang === 'zh' ? '鸣谢' : 'Thanks'}</a>
      <a href={lang === 'zh' ? '/zh/security/' : '/security/'}>{lang === 'zh' ? '安全' : 'Security'}</a>
      <a href="https://github.com/zhitongblog/solomd" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/zhitongblog/solomd/releases" target="_blank" rel="noopener">Releases</a>
      <a href="https://github.com/zhitongblog/solomd/blob/main/LICENSE" target="_blank" rel="noopener">License</a>
    </div>
    <div class="footer__legal">
      © {year} xiangdong li · {tr.footer.legal}
      <br />
      {tr.footer.stack}
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 40px 0;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }
  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }
  .footer__brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 18px;
  }
  .footer__name { font-weight: 700; }
  .footer__links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .footer__links a {
    color: var(--text-muted);
    font-size: 13px;
  }
  .footer__links a:hover { color: var(--accent); }
  .footer__legal {
    font-size: 11px;
    color: var(--text-faint);
    line-height: 1.7;
  }
</style>
