---
import { getT, type Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = getT(lang);

const VERSION = '1.1.5';
const REPO = 'zhitongblog/solomd';
const baseUrl = `https://github.com/${REPO}/releases/download/v${VERSION}`;

// Default (SSR / no-JS / unknown OS) → mac dmg link
const defaultDownload = `${baseUrl}/SoloMD_${VERSION}_universal.dmg`;

// ---- Fetch stats at BUILD time (Cloudflare Pages runs this fresh) ----
// This guarantees the numbers render even if the client-side API call
// gets rate-limited. Client-side JS can still update to a newer value.
let initialStars = 0;
let initialDownloads = 0;
try {
  const [repoRes, relRes] = await Promise.all([
    fetch(`https://api.github.com/repos/${REPO}`),
    fetch(`https://api.github.com/repos/${REPO}/releases?per_page=100`),
  ]);
  if (repoRes.ok) {
    const r = await repoRes.json();
    initialStars = r.stargazers_count || 0;
  }
  if (relRes.ok) {
    const rels = await relRes.json();
    if (Array.isArray(rels)) {
      for (const rel of rels) {
        for (const a of rel.assets || []) {
          initialDownloads += a.download_count || 0;
        }
      }
    }
  }
} catch {
  // Build will just render empty badges; JS will try to fill them.
}

function fmtStars(n: number): string {
  return n >= 1000 ? `⭐ ${(n / 1000).toFixed(1)}k` : `⭐ ${n}`;
}
function fmtDownloads(n: number): string {
  return n >= 1000 ? `${(n / 1000).toFixed(1)}k downloads` : `${n} downloads`;
}
const initialStarsText = initialStars > 0 ? fmtStars(initialStars) : '';
const initialDownloadsText = initialDownloads > 0 ? fmtDownloads(initialDownloads) : '';
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__badge">{tr.hero.badge} · <span id="hero-stars">{initialStarsText}</span> · <span id="hero-dl-count">{initialDownloadsText}</span></div>
    <h1>
      {tr.hero.title1}<br />
      <span class="hero__accent">{tr.hero.title2}</span>
    </h1>
    <p class="lead">{tr.hero.lead}</p>
    <div class="hero__cta">
      <a
        id="hero-download"
        href={defaultDownload}
        class="btn btn--primary btn--lg"
        data-default-text={tr.hero.ctaPrimary}
        data-mac-text={tr.hero.ctaForMac}
        data-win-text={tr.hero.ctaForWindows}
        data-linux-text={tr.hero.ctaForLinux}
        data-mac-href={`${baseUrl}/SoloMD_${VERSION}_universal.dmg`}
        data-win-href={`${baseUrl}/SoloMD_${VERSION}_x64_en-US.msi`}
        data-linux-href={`${baseUrl}/SoloMD_${VERSION}_amd64.AppImage`}
      >
        ⬇ {tr.hero.ctaPrimary}
      </a>
      <a
        href="https://github.com/zhitongblog/solomd"
        target="_blank"
        rel="noopener"
        class="btn btn--secondary btn--lg"
      >
        {tr.hero.ctaSecondary}
      </a>
    </div>
    <div class="hero__install">
      <div class="hero__install-label">
        ⚡ {lang === 'zh' ? '或一键安装命令' : 'Or one-line install'}
      </div>
      <div class="hero__install-tabs">
        <button class="hi-tab hi-tab--active" data-hi-tab="unix">macOS / Linux</button>
        <button class="hi-tab" data-hi-tab="win">Windows</button>
      </div>
      <div class="hi-panel hi-panel--active" data-hi-panel="unix">
        <code class="hi-code">curl -fsSL https://solomd.app/install.sh | bash</code>
        <button class="hi-copy" data-hi-copy="curl -fsSL https://solomd.app/install.sh | bash" title="Copy">📋</button>
      </div>
      <div class="hi-panel" data-hi-panel="win">
        <code class="hi-code">irm https://solomd.app/install.ps1 | iex</code>
        <button class="hi-copy" data-hi-copy="irm https://solomd.app/install.ps1 | iex" title="Copy">📋</button>
      </div>
    </div>
    <a href="#download" class="hero__all-platforms">{tr.hero.ctaAllPlatforms}</a>
    <div class="hero__chips">
      {tr.hero.chips.map((c) => <span class="chip">{c}</span>)}
    </div>
  </div>
</section>

<script is:inline>
  // Fetch live stars + downloads from our own /api/stats endpoint.
  // Cloudflare Pages Functions proxies GitHub API server-side with a 5-min
  // edge cache, so clients are never rate-limited and numbers update every
  // ~5 minutes automatically (no redeploy needed).
  (function () {
    fetch('/api/stats')
      .then(function (r) { return r.ok ? r.json() : null; })
      .then(function (stats) {
        if (!stats) return;
        if (stats.stars != null) {
          var el = document.getElementById('hero-stars');
          if (el) {
            el.textContent = stats.stars >= 1000
              ? '⭐ ' + (stats.stars / 1000).toFixed(1) + 'k'
              : '⭐ ' + stats.stars;
          }
        }
        if (stats.downloads != null) {
          var text = stats.downloads >= 1000
            ? (stats.downloads / 1000).toFixed(1) + 'k downloads'
            : stats.downloads + ' downloads';
          var el2 = document.getElementById('hero-dl-count');
          if (el2) el2.textContent = text;
          var el3 = document.getElementById('dl-section-count');
          if (el3) el3.textContent = stats.downloads.toLocaleString() + '+';
        }
      })
      .catch(function () { /* fall back to the build-time numbers in HTML */ });
  })();

  // Detect the visitor's OS and rewrite the hero download button to point at
  // the right artifact directly. Falls back gracefully to the universal mac
  // dmg if detection fails or the user has scripting disabled.
  (function () {
    var btn = document.getElementById('hero-download');
    if (!btn) return;
    var ua = navigator.userAgent || '';
    var platform = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
    var os = 'mac';
    if (/Win/i.test(ua) || /Windows/i.test(platform)) os = 'win';
    else if (/Linux/i.test(ua) && !/Android/i.test(ua)) os = 'linux';
    else if (/Mac|iPhone|iPad/i.test(ua) || /Mac/i.test(platform)) os = 'mac';
    var href = btn.getAttribute('data-' + os + '-href');
    var text = btn.getAttribute('data-' + os + '-text');
    if (href) btn.setAttribute('href', href);
    if (text) btn.innerHTML = '⬇ ' + text;

    // Also switch the one-line install block to Windows if user is on Windows
    if (os === 'win') {
      var winTab = document.querySelector('.hi-tab[data-hi-tab="win"]');
      if (winTab) winTab.click();
    }
  })();

  // One-line install: tab switch + copy-to-clipboard
  (function () {
    var tabs = document.querySelectorAll('.hi-tab');
    var panels = document.querySelectorAll('.hi-panel');
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        var target = tab.getAttribute('data-hi-tab');
        tabs.forEach(function (t) { t.classList.remove('hi-tab--active'); });
        tab.classList.add('hi-tab--active');
        panels.forEach(function (p) {
          if (p.getAttribute('data-hi-panel') === target) {
            p.classList.add('hi-panel--active');
          } else {
            p.classList.remove('hi-panel--active');
          }
        });
      });
    });
    var copyBtns = document.querySelectorAll('.hi-copy');
    copyBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var text = btn.getAttribute('data-hi-copy') || '';
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(function () {
            var orig = btn.textContent;
            btn.classList.add('copied');
            btn.textContent = '✓';
            setTimeout(function () {
              btn.classList.remove('copied');
              btn.textContent = orig;
            }, 1500);
          });
        }
      });
    });
  })();
</script>

<style>
  .hero {
    padding: 100px 0 60px;
    text-align: center;
    background: radial-gradient(ellipse at top, var(--accent-soft) 0%, transparent 55%);
  }
  .hero__inner { max-width: 880px; }
  .hero__badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 24px;
    font-family: var(--font-mono);
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    margin-bottom: 28px;
  }
  .hero__accent { color: var(--accent); }
  .hero .lead { margin: 0 auto 36px; }
  .hero__cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .btn--lg {
    padding: 14px 28px;
    font-size: 15px;
    border-radius: 10px;
  }
  .hero__all-platforms {
    display: inline-block;
    color: var(--text-muted);
    font-size: 13px;
    text-decoration: none;
    margin: 18px 0 36px;
  }
  .hero__all-platforms:hover {
    color: var(--accent);
  }

  /* One-line install block in Hero */
  .hero__install {
    max-width: 620px;
    margin: 22px auto 0;
    text-align: left;
  }
  .hero__install-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-muted);
    text-align: center;
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }
  .hero__install-tabs {
    display: flex;
    gap: 4px;
    justify-content: center;
    margin-bottom: 8px;
  }
  .hi-tab {
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 500;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 5px;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
  }
  .hi-tab:hover { color: var(--text); }
  .hi-tab--active {
    background: var(--bg-elev);
    border-color: var(--accent);
    color: var(--accent);
  }
  .hi-panel {
    display: none;
    position: relative;
  }
  .hi-panel--active { display: block; }
  .hi-code {
    display: block;
    padding: 12px 50px 12px 16px;
    background: var(--ink, #0e0e0c);
    color: #e8e6de;
    border-radius: 8px;
    font-family: var(--font-mono, 'SF Mono', Menlo, Consolas, monospace);
    font-size: 13px;
    overflow-x: auto;
    white-space: nowrap;
    text-align: left;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
  .hi-copy {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 32px;
    height: 32px;
    padding: 0;
    font-size: 14px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 5px;
    color: #e8e6de;
    cursor: pointer;
    transition: all 0.15s;
  }
  .hi-copy:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #000;
  }
  .hi-copy.copied {
    background: #2ea043;
    border-color: #2ea043;
    color: white;
  }
  .hero__chips {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .chip {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
