---
import { getT, type Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = getT(lang);

const VERSION = '0.1.6';
const REPO = 'zhitongblog/solomd';
const baseUrl = `https://github.com/${REPO}/releases/download/v${VERSION}`;

// Default (SSR / no-JS / unknown OS) → mac dmg link
const defaultDownload = `${baseUrl}/SoloMD_${VERSION}_universal.dmg`;
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__badge">{tr.hero.badge} · <span id="hero-stars"></span> · <span id="hero-dl-count"></span></div>
    <h1>
      {tr.hero.title1}<br />
      <span class="hero__accent">{tr.hero.title2}</span>
    </h1>
    <p class="lead">{tr.hero.lead}</p>
    <div class="hero__cta">
      <a
        id="hero-download"
        href={defaultDownload}
        class="btn btn--primary btn--lg"
        data-default-text={tr.hero.ctaPrimary}
        data-mac-text={tr.hero.ctaForMac}
        data-win-text={tr.hero.ctaForWindows}
        data-linux-text={tr.hero.ctaForLinux}
        data-mac-href={`${baseUrl}/SoloMD_${VERSION}_universal.dmg`}
        data-win-href={`${baseUrl}/SoloMD_${VERSION}_x64_en-US.msi`}
        data-linux-href={`${baseUrl}/SoloMD_${VERSION}_amd64.AppImage`}
      >
        ⬇ {tr.hero.ctaPrimary}
      </a>
      <a
        href="https://github.com/zhitongblog/solomd"
        target="_blank"
        rel="noopener"
        class="btn btn--secondary btn--lg"
      >
        {tr.hero.ctaSecondary}
      </a>
    </div>
    <a href="#download" class="hero__all-platforms">{tr.hero.ctaAllPlatforms}</a>
    <div class="hero__chips">
      {tr.hero.chips.map((c) => <span class="chip">{c}</span>)}
    </div>
  </div>
</section>

<script is:inline>
  // Fetch total download count from GitHub Releases API and display it.
  (function () {
    fetch('https://api.github.com/repos/zhitongblog/solomd/releases')
      .then(function (r) { return r.json(); })
      .then(function (releases) {
        if (!Array.isArray(releases)) return;
        var total = 0;
        for (var i = 0; i < releases.length; i++) {
          var assets = releases[i].assets || [];
          for (var j = 0; j < assets.length; j++) {
            total += assets[j].download_count || 0;
          }
        }
        var text = total >= 10000
          ? (total / 1000).toFixed(1) + 'k downloads'
          : total >= 1000
            ? (total / 1000).toFixed(1) + 'k downloads'
            : total + ' downloads';
        var el = document.getElementById('hero-dl-count');
        if (el) el.textContent = text;
        var el2 = document.getElementById('dl-section-count');
        if (el2) el2.textContent = total.toLocaleString() + '+';
      })
      .catch(function () {
        var el = document.getElementById('hero-dl-count');
        if (el) el.style.display = 'none';
      });
  })();

  // Fetch GitHub stars count
  (function () {
    fetch('https://api.github.com/repos/zhitongblog/solomd')
      .then(function (r) { return r.json(); })
      .then(function (repo) {
        var stars = repo.stargazers_count || 0;
        var text = stars >= 1000 ? (stars / 1000).toFixed(1) + 'k' : String(stars);
        var el = document.getElementById('hero-stars');
        if (el) el.textContent = '⭐ ' + text;
      })
      .catch(function () {
        var el = document.getElementById('hero-stars');
        if (el) el.style.display = 'none';
      });
  })();

  // Detect the visitor's OS and rewrite the hero download button to point at
  // the right artifact directly. Falls back gracefully to the universal mac
  // dmg if detection fails or the user has scripting disabled.
  (function () {
    var btn = document.getElementById('hero-download');
    if (!btn) return;
    var ua = navigator.userAgent || '';
    var platform = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
    var os = 'mac';
    if (/Win/i.test(ua) || /Windows/i.test(platform)) os = 'win';
    else if (/Linux/i.test(ua) && !/Android/i.test(ua)) os = 'linux';
    else if (/Mac|iPhone|iPad/i.test(ua) || /Mac/i.test(platform)) os = 'mac';
    var href = btn.getAttribute('data-' + os + '-href');
    var text = btn.getAttribute('data-' + os + '-text');
    if (href) btn.setAttribute('href', href);
    if (text) btn.innerHTML = '⬇ ' + text;
  })();
</script>

<style>
  .hero {
    padding: 100px 0 60px;
    text-align: center;
    background: radial-gradient(ellipse at top, var(--accent-soft) 0%, transparent 55%);
  }
  .hero__inner { max-width: 880px; }
  .hero__badge {
    display: inline-block;
    padding: 6px 14px;
    border-radius: 999px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
    margin-bottom: 24px;
    font-family: var(--font-mono);
  }
  .hero h1 {
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    margin-bottom: 28px;
  }
  .hero__accent { color: var(--accent); }
  .hero .lead { margin: 0 auto 36px; }
  .hero__cta {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .btn--lg {
    padding: 14px 28px;
    font-size: 15px;
    border-radius: 10px;
  }
  .hero__all-platforms {
    display: inline-block;
    color: var(--text-muted);
    font-size: 13px;
    text-decoration: none;
    margin-bottom: 36px;
  }
  .hero__all-platforms:hover {
    color: var(--accent);
  }
  .hero__chips {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .chip {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
