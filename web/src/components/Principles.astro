---
import { getT, type Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = getT(lang);
---

<section id="principles" class="principles">
  <div class="container">
    <div class="principles__header">
      <h2>{tr.principles.heading}</h2>
      <p class="lead">{tr.principles.lead}</p>
    </div>
    <div class="principles__grid">
      {tr.principles.items.map((p) => (
        <article class="pcard">
          <div class="pcard__icon">{p.icon}</div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          {p.link && (
            <a class="pcard__link" href={p.link.href}>{p.link.label}</a>
          )}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .principles__header {
    text-align: center;
    margin-bottom: 44px;
    max-width: 720px;
    margin-left: auto;
    margin-right: auto;
  }
  .principles__header .lead { margin: 16px auto 0; }

  .principles__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }
  .pcard {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 22px 22px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  }
  .pcard:hover {
    border-color: color-mix(in srgb, var(--accent) 36%, var(--border));
    transform: translateY(-2px);
    box-shadow: 0 14px 30px -16px rgba(255, 159, 64, 0.22);
  }
  .pcard__icon {
    font-size: 28px;
    line-height: 1;
    margin-bottom: 4px;
  }
  .pcard h3 {
    font-size: 0.98rem;
    margin: 0;
    line-height: 1.3;
  }
  .pcard p {
    margin: 0;
    color: var(--text-muted);
    font-size: 13px;
    line-height: 1.6;
  }
  .pcard__link {
    margin-top: auto;
    padding-top: 6px;
    color: var(--accent);
    font-size: 12.5px;
    font-weight: 600;
    text-decoration: none;
    border: none;
  }
  .pcard__link:hover {
    text-decoration: underline;
  }
</style>
