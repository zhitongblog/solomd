---
import type { Lang } from '../i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;

const STR = {
  en: {
    heading: 'Contact / Join the room',
    lead: 'One maintainer, two front doors. WeChat for the Chinese community, Telegram channel for everyone else. GitHub Discussions works too — link below.',
    wechatLabel: 'WeChat (personal)',
    wechatHint: 'Scan to add me on WeChat. Mention "SoloMD" so I know it\'s you.',
    telegramLabel: 'Telegram channel @SOLOMDAPP',
    telegramHint: 'Click or scan to join. Release announcements + chat live here.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, public, searchable — same maintainer, no DM required.',
  },
  zh: {
    heading: '联系作者 / 加群',
    lead: '一个开发者,直接微信或 Telegram 找我。GitHub Discussions 也是一个等价入口 —— 见下面。',
    wechatLabel: '个人微信',
    wechatHint: '扫码加好友。注明 "SoloMD" 直接通过。',
    telegramLabel: 'Telegram 频道 @SOLOMDAPP',
    telegramHint: '点击或扫码进入频道,发布更新和讨论都在这里。',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: '不想加私聊? 可在 GitHub 公开频道讨论 —— 同一作者,异步。',
  },
  ja: {
    heading: 'お問い合わせ / コミュニティ',
    lead: 'メンテナは 1 人、入り口は 2 つ。中国語コミュニティは WeChat、それ以外は Telegram チャンネル。GitHub Discussions も動きます —— 下にリンク。',
    wechatLabel: 'WeChat (個人)',
    wechatHint: 'WeChat 友達追加用 QR。「SoloMD」と書いてもらえると承認します。',
    telegramLabel: 'Telegram チャンネル @SOLOMDAPP',
    telegramHint: 'クリックまたはスキャンで参加。リリース告知とチャットはここ。',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: '非同期、公開、検索可能 —— 同じメンテナ、DM 不要。',
  },
  ko: {
    heading: '문의 / 커뮤니티',
    lead: '메인테이너 1명, 입구 2개. 중국어 커뮤니티는 WeChat, 그 외는 Telegram 채널. GitHub Discussions도 가능 —— 아래 링크.',
    wechatLabel: 'WeChat (개인)',
    wechatHint: 'WeChat 친구 추가용 QR. "SoloMD"라고 적어주시면 승인합니다.',
    telegramLabel: 'Telegram 채널 @SOLOMDAPP',
    telegramHint: '클릭하거나 스캔하여 참여. 릴리스 공지 + 채팅이 여기 있습니다.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: '비동기, 공개, 검색 가능 —— 같은 메인테이너, DM 불필요.',
  },
  de: {
    heading: 'Kontakt / Community beitreten',
    lead: 'Ein Maintainer, zwei Eingangstüren. WeChat für die chinesische Community, Telegram-Kanal für alle anderen. GitHub Discussions funktioniert auch — Link unten.',
    wechatLabel: 'WeChat (persönlich)',
    wechatHint: 'Scannen, um mich auf WeChat hinzuzufügen. Erwähnen Sie "SoloMD", damit ich weiß, dass Sie es sind.',
    telegramLabel: 'Telegram-Kanal @SOLOMDAPP',
    telegramHint: 'Klicken oder scannen zum Beitreten. Release-Ankündigungen + Chat leben hier.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, öffentlich, durchsuchbar — derselbe Maintainer, keine DM erforderlich.',
  },
  fr: {
    heading: 'Contact / Rejoindre la communauté',
    lead: 'Un mainteneur, deux portes d\'entrée. WeChat pour la communauté chinoise, canal Telegram pour tous les autres. GitHub Discussions fonctionne aussi — lien ci-dessous.',
    wechatLabel: 'WeChat (personnel)',
    wechatHint: 'Scanner pour m\'ajouter sur WeChat. Mentionnez « SoloMD » pour que je sache que c\'est vous.',
    telegramLabel: 'Canal Telegram @SOLOMDAPP',
    telegramHint: 'Cliquer ou scanner pour rejoindre. Annonces de release + chat vivent ici.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, public, recherchable — même mainteneur, pas de DM requis.',
  },
  es: {
    heading: 'Contacto / Unirse a la comunidad',
    lead: 'Un mantenedor, dos puertas de entrada. WeChat para la comunidad china, canal Telegram para todos los demás. GitHub Discussions también funciona — enlace abajo.',
    wechatLabel: 'WeChat (personal)',
    wechatHint: 'Escanear para añadirme en WeChat. Menciona "SoloMD" para que sepa que eres tú.',
    telegramLabel: 'Canal Telegram @SOLOMDAPP',
    telegramHint: 'Haz clic o escanea para unirte. Anuncios de release + chat viven aquí.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, público, buscable — mismo mantenedor, no se requiere DM.',
  },
  pt: {
    heading: 'Contato / Entrar na comunidade',
    lead: 'Um mantenedor, duas portas de entrada. WeChat para a comunidade chinesa, canal Telegram para todos os outros. GitHub Discussions também funciona — link abaixo.',
    wechatLabel: 'WeChat (pessoal)',
    wechatHint: 'Escaneie para me adicionar no WeChat. Mencione "SoloMD" para eu saber que é você.',
    telegramLabel: 'Canal Telegram @SOLOMDAPP',
    telegramHint: 'Clique ou escaneie para entrar. Anúncios de release + chat vivem aqui.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, público, pesquisável — mesmo mantenedor, sem DM necessário.',
  },
  it: {
    heading: 'Contatto / Unisciti alla community',
    lead: 'Un manutentore, due porte d\'ingresso. WeChat per la community cinese, canale Telegram per tutti gli altri. GitHub Discussions funziona anche — link sotto.',
    wechatLabel: 'WeChat (personale)',
    wechatHint: 'Scansiona per aggiungermi su WeChat. Menziona "SoloMD" così so che sei tu.',
    telegramLabel: 'Canale Telegram @SOLOMDAPP',
    telegramHint: 'Clicca o scansiona per unirti. Annunci di release + chat vivono qui.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, pubblico, ricercabile — stesso manutentore, nessun DM richiesto.',
  },
  pl: {
    heading: 'Kontakt / Dołącz do społeczności',
    lead: 'Jeden maintainer, dwa wejścia. WeChat dla społeczności chińskiej, kanał Telegram dla wszystkich innych. GitHub Discussions też działa — link niżej.',
    wechatLabel: 'WeChat (osobisty)',
    wechatHint: 'Zeskanuj, aby dodać mnie na WeChat. Wpisz "SoloMD", abym wiedział, że to ty.',
    telegramLabel: 'Kanał Telegram @SOLOMDAPP',
    telegramHint: 'Kliknij lub zeskanuj, aby dołączyć. Ogłoszenia release\'ów + chat odbywają się tutaj.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Asynchroniczne, publiczne, przeszukiwalne — ten sam maintainer, bez DM.',
