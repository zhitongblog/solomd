  nl: {
    heading: 'Contact / Word lid van de community',
    lead: 'Eén maintainer, twee voordeuren. WeChat voor de Chinese community, Telegram-kanaal voor iedereen anders. GitHub Discussions werkt ook — link hieronder.',
    wechatLabel: 'WeChat (persoonlijk)',
    wechatHint: 'Scan om me toe te voegen op WeChat. Vermeld "SoloMD" zodat ik weet dat jij het bent.',
    telegramLabel: 'Telegram-kanaal @SOLOMDAPP',
    telegramHint: 'Klik of scan om mee te doen. Release-aankondigingen + chat staan hier.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, openbaar, doorzoekbaar — dezelfde maintainer, geen DM nodig.',
  },
  tr: {
    heading: 'İletişim / Topluluğa katıl',
    lead: 'Bir bakımcı, iki kapı. Çin topluluğu için WeChat, diğer herkes için Telegram kanalı. GitHub Discussions de çalışıyor — link aşağıda.',
    wechatLabel: 'WeChat (kişisel)',
    wechatHint: 'WeChat\'ten beni eklemek için tara. Sen olduğunu bilmem için "SoloMD" yaz.',
    telegramLabel: 'Telegram kanalı @SOLOMDAPP',
    telegramHint: 'Katılmak için tıklayın veya tarayın. Sürüm duyuruları + sohbet burada yaşar.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, herkese açık, aranabilir — aynı bakımcı, DM gerekmez.',
  },
  sv: {
    heading: 'Kontakt / Gå med i gemenskapen',
    lead: 'En underhållare, två ytterdörrar. WeChat för den kinesiska gemenskapen, Telegram-kanal för alla andra. GitHub Discussions fungerar också — länk nedan.',
    wechatLabel: 'WeChat (personlig)',
    wechatHint: 'Skanna för att lägga till mig på WeChat. Nämn "SoloMD" så jag vet att det är du.',
    telegramLabel: 'Telegram-kanal @SOLOMDAPP',
    telegramHint: 'Klicka eller skanna för att gå med. Release-meddelanden + chatt bor här.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, offentlig, sökbar — samma underhållare, ingen DM krävs.',
  },
  uk: {
    heading: 'Контакт / Долучитися до спільноти',
    lead: 'Один підтримувач, два входи. WeChat для китайської спільноти, канал Telegram для всіх інших. GitHub Discussions також працює — посилання нижче.',
    wechatLabel: 'WeChat (особистий)',
    wechatHint: 'Скануйте, щоб додати мене у WeChat. Згадайте "SoloMD", щоб я знав, що це ви.',
    telegramLabel: 'Канал Telegram @SOLOMDAPP',
    telegramHint: 'Натисніть або скануйте, щоб приєднатися. Анонси релізів + чат живуть тут.',
    discussionsLabel: 'GitHub Discussions',
    discussionsHint: 'Async, публічно, з пошуком — той самий підтримувач, DM не потрібен.',
  },
}[lang];
const { heading, lead, wechatLabel, wechatHint, telegramLabel, telegramHint, discussionsLabel, discussionsHint } = STR;
---

<section id="contact" class="contact">
  <div class="container">
    <div class="contact__header">
      <h2>{heading}</h2>
      <p class="lead">{lead}</p>
    </div>

    <div class="contact__grid">
      <article class="contact__card">
        <div class="contact__card-body">
          <img
            src="/contact/wechat.jpg"
            alt={wechatLabel}
            loading="lazy"
            width="220"
            height="270"
          />
          <div class="contact__card-meta">
            <h3>{wechatLabel}</h3>
            <p>{wechatHint}</p>
          </div>
        </div>
      </article>

      <article class="contact__card">
        <div class="contact__card-body">
          <a href="https://t.me/SOLOMDAPP" target="_blank" rel="noopener">
            <img
              src="/contact/telegram.jpg"
              alt={telegramLabel}
              loading="lazy"
              width="220"
              height="390"
            />
          </a>
          <div class="contact__card-meta">
            <h3>
              <a href="https://t.me/SOLOMDAPP" target="_blank" rel="noopener">
                @SOLOMDAPP
              </a>
            </h3>
            <p>{telegramHint}</p>
          </div>
        </div>
      </article>

      <article class="contact__card contact__card--discussions">
        <div class="contact__card-body">
          <div class="contact__discussions-icon" aria-hidden="true">💬</div>
          <div class="contact__card-meta">
            <h3>
              <a href="https://github.com/zhitongblog/solomd/discussions" target="_blank" rel="noopener">
                {discussionsLabel} →
              </a>
            </h3>
            <p>{discussionsHint}</p>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: 64px 0;
    background: var(--bg-soft);
    border-top: 1px solid var(--border);
  }
  .contact__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .contact__header h2 {
    font-size: 1.6rem;
    margin: 0 0 12px;
  }
  .contact__header .lead {
    color: var(--text-muted);
    max-width: 560px;
    margin: 0 auto;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .contact__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 18px;
    max-width: 980px;
    margin: 0 auto;
  }
  .contact__card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 22px 22px 24px;
    display: flex;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .contact__card:hover {
    border-color: var(--accent);
  }
  .contact__card-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    align-items: center;
    text-align: center;
    width: 100%;
  }
  .contact__card-body img {
    width: 220px;
    height: auto;
    max-height: 280px;
    object-fit: contain;
    border-radius: 8px;
    background: #fff;
  }
  .contact__card-meta h3 {
    margin: 0 0 6px;
    font-size: 1rem;
    font-weight: 600;
  }
  .contact__card-meta h3 a {
    color: var(--text);
    text-decoration: none;
  }
  .contact__card-meta h3 a:hover {
    color: var(--accent);
  }
  .contact__card-meta p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .contact__card--discussions {
    background: var(--bg);
  }
  .contact__discussions-icon {
    font-size: 56px;
    line-height: 1;
    width: 220px;
    max-height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-faint);
  }
</style>
