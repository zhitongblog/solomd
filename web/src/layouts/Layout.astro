---
import '../styles/global.css';
import type { Lang } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
  lang?: Lang;
}

const {
  title = 'SoloMD — Lightweight Markdown editor',
  description = 'A lightweight, cross-platform Markdown + plain text editor.',
  lang = 'en',
} = Astro.props;

const HTML_LANG = { en: 'en', zh: 'zh-CN', ja: 'ja', ko: 'ko' } as const;
const OG_LOCALE = { en: 'en_US', zh: 'zh_CN', ja: 'ja_JP', ko: 'ko_KR' } as const;
const htmlLang = HTML_LANG[lang];
const path = lang === 'en' ? '/' : `/${lang}/`;
const ogLocale = OG_LOCALE[lang];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="alternate" hreflang="en" href="https://solomd.app/" />
    <link rel="alternate" hreflang="zh-CN" href="https://solomd.app/zh/" />
    <link rel="alternate" hreflang="ja" href="https://solomd.app/ja/" />
    <link rel="alternate" hreflang="ko" href="https://solomd.app/ko/" />
    <link rel="alternate" hreflang="x-default" href="https://solomd.app/" />
    <link rel="canonical" href={`https://solomd.app${path}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://solomd.app${path}`} />
    <meta property="og:site_name" content="SoloMD" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content="https://solomd.app/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://solomd.app/og-image.png" />

    <meta name="theme-color" content="#ff9f40" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0e0e0c" media="(prefers-color-scheme: dark)" />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <!-- Marketing-site display serif. Source Serif 4 by Adobe, OFL — used
         only on /landing and /blog headings; the desktop app does not
         load any external font. preconnect keeps the round-trips off
         the critical path. font-display: swap means the page renders
         immediately in system serif if the network is slow. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap" />

    <!-- Sitemap discovery hint -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

    <!-- JSON-LD: BreadcrumbList -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "SoloMD", "item": "https://solomd.app/" },
        ...(lang === 'zh' ? [{ "@type": "ListItem", "position": 2, "name": "中文", "item": "https://solomd.app/zh/" }] : []),
        ...(lang === 'ja' ? [{ "@type": "ListItem", "position": 2, "name": "日本語", "item": "https://solomd.app/ja/" }] : []),
        ...(lang === 'ko' ? [{ "@type": "ListItem", "position": 2, "name": "한국어", "item": "https://solomd.app/ko/" }] : []),
      ]
    })} />

    <!-- JSON-LD: SoftwareApplication (helps Google software result cards + LLM citations) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SoloMD",
      "alternateName": ["#MD", "Solo MD"],
      "description": "A lightweight, cross-platform Markdown + plain text editor for macOS, Windows, and Linux. One file. One window. Just write.",
      "applicationCategory": "ProductivityApplication",
      "applicationSubCategory": "Text Editor",
      "operatingSystem": "macOS, Windows, Linux",
      "softwareVersion": "2.3",
      "fileSize": "15MB",
      "url": "https://solomd.app",
      "downloadUrl": "https://github.com/zhitongblog/solomd/releases",
      "license": "https://opensource.org/licenses/MIT",
      "softwareRequirements": "macOS 11+, Windows 10+, or Linux x64",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
      },
      "author": {
        "@type": "Person",
        "name": "xiangdong li",
        "url": "https://github.com/zhitongblog",
      },
      "publisher": {
        "@type": "Person",
        "name": "xiangdong li",
      },
      "featureList": [
        "Local semantic search (on-device embedder, no cloud)",
        "WYSIWYG live edit view mode",
        "AutoGit per-save version history with one-click restore",
        "MCP server for Claude Desktop / Cursor / Codex CLI",
        "AI rewrite with 14 BYOK providers (OS keychain)",
        "Live Preview Markdown editor",
        "KaTeX math rendering",
        "Mermaid diagrams",
        "Image paste & drag-drop",
        "Global ripgrep search",
        "Multi-encoding support (UTF-8/GBK/Big5)",
        "Pandoc export to PDF, DOCX, EPUB, ODT, LaTeX",
        "Light & dark themes",
        "Custom CSS theme",
        "Cross-platform native menus",
      ],
      "inLanguage": ["en", "zh-CN", "ja", "ko"],
    })} />

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-7786364053868586">
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7786364053868586" crossorigin="anonymous"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
