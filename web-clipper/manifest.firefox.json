{
  "manifest_version": 2,
  "name": "SoloMD Web Clipper",
  "version": "2.4.0",
  "description": "Save the current page, your selection, or just the link to your local SoloMD inbox. Local-only — never phones home.",
  "default_locale": "en",
  "browser_specific_settings": {
    "gecko": {
      "id": "web-clipper@solomd.app",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "browser_action": {
    "default_title": "SoloMD Web Clipper",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "contextMenus",
    "notifications",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "commands": {
    "clip-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Clip selection (or whole page if no selection)"
    },
    "save-link": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Save link to current page"
    }
  }
}
